---
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "VPM package listing" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/png" sizes="32x32" href="/Aviane logo - Round Safe.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/Aviane logo - Round Safe.png" />
    <link rel="apple-touch-icon" href="/Aviane logo - Round Safe.png" />
  </head>
  <body class="bg-[#07000d] min-h-screen antialiased overflow-x-hidden">
    <main class="relative z-10">
      <slot />
    </main>
  </body>
</html>
